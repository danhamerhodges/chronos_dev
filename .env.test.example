APP_ENV=test
APP_HOST=127.0.0.1
APP_PORT=8001

SUPABASE_URL_DEV=https://your-project.supabase.co
SUPABASE_ANON_KEY_DEV=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_replace_me

# Frontend (Vite) public aliases consumed by web/src/lib/supabaseClient.ts.
# VITE_SUPABASE_URL_DEV=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY_DEV=sb_publishable_replace_me

AUTH_SESSION_TTL_MINUTES=30
AUTH_MAX_FAILED_ATTEMPTS=3
AUTH_LOCKOUT_MINUTES=5

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SUBSCRIPTION_PRODUCT_ID=prod_replace_me
STRIPE_SUBSCRIPTION_PRICE_ID=price_replace_me
STRIPE_OVERAGE_PRODUCT_ID=prod_replace_me
STRIPE_OVERAGE_PRICE_ID=price_replace_me

METRICS_ENABLED=true
METRICS_NAMESPACE=chronos_test
LOG_LEVEL=DEBUG

# Integration toggles (disabled by default for unit-only mode).
CHRONOS_RUN_SUPABASE_INTEGRATION=0
CHRONOS_RUN_STRIPE_INTEGRATION=0
CHRONOS_TEST_EMAIL=
CHRONOS_TEST_PASSWORD=
CHRONOS_TEST_STRIPE_CUSTOMER_ID=
