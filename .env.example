APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

# Active local naming pattern.
SUPABASE_URL_DEV=https://your-project.supabase.co
SUPABASE_ANON_KEY_DEV=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_replace_me
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=replace_me

# Canonical compatibility aliases accepted by app/config.py fallback logic.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=sb_publishable_replace_me

# Frontend (Vite) public aliases consumed by web/src/lib/supabaseClient.ts.
# VITE_SUPABASE_URL_DEV=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY_DEV=sb_publishable_replace_me

AUTH_SESSION_TTL_MINUTES=60
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_REQUIRE_EMAIL_VERIFICATION=true
AUTH_OAUTH_GOOGLE_ENABLED=true
AUTH_OAUTH_GITHUB_ENABLED=true
AUTH_MAGIC_LINK_ENABLED=true

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SUBSCRIPTION_PRODUCT_ID=prod_replace_me
STRIPE_SUBSCRIPTION_PRICE_ID=price_replace_me
STRIPE_OVERAGE_PRODUCT_ID=prod_replace_me
STRIPE_OVERAGE_PRICE_ID=price_replace_me
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:3000/account/billing

# Canonical compatibility aliases accepted by app/config.py fallback logic.
# STRIPE_PRODUCT_ID=prod_replace_me
# STRIPE_PRICE_ID=price_replace_me

METRICS_ENABLED=true
METRICS_NAMESPACE=chronos_dev
LOG_LEVEL=INFO

SLO_AVAILABILITY_TARGET=99.9
SLO_P95_LATENCY_MS_TARGET=250
SLO_ERROR_RATE_TARGET=1.0
SLO_INGEST_SUCCESS_TARGET=99.5

PAGERDUTY_ROUTING_KEY=replace_me
SLACK_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
