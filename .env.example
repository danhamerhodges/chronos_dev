APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000
METRICS_ENABLED=true
METRICS_NAMESPACE=chronos_local
LOG_LEVEL=INFO

# Optional hosted integration values for local development against the shared
# chronos_dev staging / pre-prod environment. Leave these unset for the default
# local no-external path.
# SUPABASE_URL_DEV=https://your-project.supabase.co
# SUPABASE_ANON_KEY_DEV=sb_publishable_replace_me
# SUPABASE_SERVICE_ROLE_KEY=sb_service_role_replace_me
# SUPABASE_DB_HOST=db.your-project.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=replace_me

# Canonical runtime aliases accepted by app/config.py fallback logic.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=sb_publishable_replace_me

# Frontend (Vite) compatibility aliases consumed by web/src/lib/supabaseClient.ts.
# VITE_SUPABASE_URL_DEV=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY_DEV=sb_publishable_replace_me
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=sb_publishable_replace_me

AUTH_SESSION_TTL_MINUTES=60
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Optional billing integration values.
# STRIPE_SECRET_KEY=sk_test_replace_me
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
# STRIPE_SUBSCRIPTION_PRODUCT_ID=prod_replace_me
# STRIPE_SUBSCRIPTION_PRICE_ID=price_replace_me
# STRIPE_OVERAGE_PRODUCT_ID=prod_replace_me
# STRIPE_OVERAGE_PRICE_ID=price_replace_me
# STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:3000/account/billing

# Canonical runtime aliases accepted by app/config.py fallback logic.
# STRIPE_PRODUCT_ID=prod_replace_me
# STRIPE_PRICE_ID=price_replace_me

# Optional hosted runtime and ops values.
# GCP_PROJECT_ID=chronos-dev-489301
# GCP_REGION=us-central1
# GCS_BUCKET_NAME=chronos-media
# REDIS_URL=redis://127.0.0.1:6379/0
# JOB_DISPATCH_MODE=memory
# JOB_PROGRESS_MODE=memory
# SEGMENT_CACHE_MODE=memory
# JOB_WORKER_TRUSTED_TOKEN=replace_me
# OUTPUT_DELIVERY_SIGNING_SECRET=chronos-output-delivery-dev-secret
# SLACK_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
